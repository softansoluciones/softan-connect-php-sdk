{
  "sdk_name": "Softan Connect SDK",
  "sdk_version": "0.0.8",
  "sdk_type": "php",
  "sdk_author": "Softan Soluciones",
  "default_environment": "stg",
  "base_urls": {
    "dev":  "http://localhost/softan-connect/main-api-v2/public/",
    "stg":  "https://connect-stg.softansoluciones.com/public/",
    "prod": "https://connect.softansoluciones.com/public/"
  },
  "endpoints": {
    "tokens": {
      "create": "tokens",
      "status": "tokens/status"
    },
    "otp": {
      "create": "otp",
      "validate": "otp/validate"
    },
    "developers": {
      "validate": "developers/validate"
    }
  }
}
